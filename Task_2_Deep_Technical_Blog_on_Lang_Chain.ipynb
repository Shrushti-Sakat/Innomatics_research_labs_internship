"\n      )\n",\n      "\n",\n        "chain = prompt | llm\n",\n        "\n",\n        "response = chain.invoke({})\n",\n        "\n",\n        "text = response.strip()\n",\n        "\n",\n        "# Split into sentences\n",\n        "sentences = text.split(\".\")\n",\n        "\n",\n        "# Clean valid sentences only\n",\n        "clean_points = []\n",\n        "for s in sentences:\n",\n        "    s = s.strip()\n",\n        "    if len(s) > 20 and \"LangChain\" in s:\n",\n        "        clean_points.append(s)\n",\n        "    if len(clean_points) == 3:\n",\n        "        break\n",\n        "\n",\n        "# If model fails, fallback manual answer\n",\n        "if len(clean_points) < 3:\n",\n        "    clean_points = [\n",\n        "        \"LangChain is a framework for building applications using language models\",\n",\n        "        \"It helps connect prompts, memory, and tools\",\n",\n        "        \"It is widely used in chatbots and AI systems\"\n",\n        "    ]\n",\n        "\n",\n        "# Print final output\n",\n        "for i, point in enumerate(clean_points, 1):\n",\n        "    print(f\"{i}. {point}\")"\n      ],\n      "metadata": {\n        "colab": {\n          "base_uri": "https://localhost:8080/"\n        },\n        "id": "YgpL26P6_VWx",\n        "outputId": "4de9373d-2040-4dff-896c-d9703c2856b7"\n      },\n      "execution_count": 24,\n      "outputs": [\n        {\n          "output_type": "stream",\n          "name": "stderr",\n          "text": [\n            "Setting `pad_token_id` to `eos_token_id`:50256 for open-end generation.\n",\n            "Both `max_new_tokens` (=80) and `max_length`(=50) seem to have been set. `max_new_tokens` will take precedence. Please refer to the documentation for more information. (https://huggi[...]"\n          ]\n        },\n        {\n          "output_type": "stream",\n          "name": "stdout",\n          "text": [\n            "1. LangChain is a framework for building applications us